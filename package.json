{
  "name": "al-mcp-bridge",
  "version": "0.1.0",
  "description": "MCP server bridging AI agents to the AL language server for semantic AL code authoring and refactoring.",
  "type": "module",
  "bin": {
    "al-mcp-bridge": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "install:al-ls": "node scripts/install-al-ls.mjs",
    "install:al-ls:status": "node scripts/install-al-ls.mjs --status",
    "pretest:e2e": "npm run build && npm run install:al-ls",
    "test:e2e": "node --test --test-reporter=spec \"tests/e2e/**/*.test.mjs\"",
    "test": "npm run test:e2e"
  },
  "keywords": ["mcp", "al", "business-central", "dynamics-nav", "lsp", "refactoring"],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "alLanguageServer": {
    "version": "17.0.2273547",
    "_comment": "Pinned AL VS Code extension version used by the e2e test harness. Bump together with tests/.al-ls/ cache invalidation."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
